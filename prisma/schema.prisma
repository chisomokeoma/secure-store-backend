generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum MeasurementUnit {
  METRIC_TON
  KILOGRAM
  METER
  BAG
  UNIT
  LITRE
}

// Phase 1: receipt-tree-ledger refactor.
// Node lifecycle for the immutable UTXO-style receipt tree.
enum ReceiptStatus {
  ACTIVE // live, transactable leaf
  PENDING_APPROVAL // graded by warehouse manager, awaiting approval
  HELD_WITHDRAWAL // reserved by an in-flight withdrawal
  HELD_LOAN // pledged as live loan collateral
  HELD_TRADE // listed on the exchange
  WITHDRAWN // terminal: physically removed
  TRADED_OUT // terminal: ownership transferred via sale
  SEIZED // terminal: collateral taken on loan default
  EXPIRED // terminal: lapsed
  CANCELLED // terminal: rejected deposit / dead
  SPLIT // superseded internal node (has children)
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TxnType {
  DEPOSIT
  WITHDRAWAL
  LOAN
  TRADE
  ADJUSTMENT
}

enum InventoryEventType {
  DEPOSIT
  APPROVED
  REJECTED
  HOLD_PLACED
  HOLD_RELEASED
  CONSUMED
  OWNERSHIP_TRANSFERRED
  SEIZED
  EXPIRED
  CANCELLED
  LEGACY_RECONCILIATION
}

enum WithdrawalStatus {
  PENDING_PAYMENT
  PAID_PENDING_APPROVAL
  APPROVED
  REJECTED
  COMPLETED
}

enum LoanStatus {
  PENDING
  APPROVED
  ACTIVE
  REPAID
  DEFAULTED
  REJECTED
  CANCELLED
}

enum TradeStatus {
  LISTED
  PENDING_SETTLEMENT
  SETTLED
  CANCELLED
}

enum GradingLogic {
  PERCENTAGE
  SCORE
  PASS_FAIL
}

enum FeeType {
  PER_MT_PER_MONTH
  PER_BAG_PER_WEEK
  PER_MT_PER_DAY
  FLAT_RATE
}

enum NotificationType {
  // Client lifecycle
  CLIENT_REGISTERED
  CLIENT_CREDENTIALS_ISSUED

  // Deposits / receipt approval
  DEPOSIT_PENDING_APPROVAL
  DEPOSIT_APPROVED
  DEPOSIT_REJECTED

  // Withdrawals
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_PAYMENT_CONFIRMED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  WITHDRAWAL_DISPATCHED

  // Loans
  LOAN_REQUESTED
  LOAN_APPROVED
  LOAN_REJECTED
  LOAN_REPAID
  LOAN_DEFAULTED

  // Trades
  TRADE_LISTED
  TRADE_SOLD
  TRADE_CANCELLED
}

enum BillingFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DEACTIVATED
}

enum ClientType {
  FARMER
  TRADER
  COMPANY
  OTHER
}

// ==========================================
// MODELS
// ==========================================

model Tenant {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                User[]
  warehouses           Warehouse[]
  commodities          Commodity[]
  receipts             Receipt[]
  withdrawals          Withdrawal[]
  loans                Loan[]
  trades               Trade[]
  financiers           Financier[]
  warehouseCommodities WarehouseCommodity[]
  gradingParameters    GradingParameter[]
  storageFeePolicies   StorageFeePolicy[]
  managerAssignments   WarehouseManagerAssignment[]
  activityLogs         ActivityLog[]
  inventoryEvents      InventoryEvent[]
  clientProfiles       ClientProfile[]
  clientFocusCommodities ClientFocusCommodity[]
  notifications        Notification[]

  @@map("tenants")
}

model User {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  firstName String @map("first_name")
  lastName  String @map("last_name")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  roles UserRole[]

  // Profile fields from spec §1.0
  phoneNumber        String?    @map("phone_number")
  middleName         String?    @map("middle_name")
  dateOfBirth        DateTime?  @map("date_of_birth")
  gender             String?
  residentialAddress String?    @map("residential_address")
  employmentDate     DateTime?  @map("employment_date")
  managerCode        String?    @unique @map("manager_code")
  profilePhotoUrl    String?    @map("profile_photo_url")
  contactEmail       String?    @map("contact_email")
  status             UserStatus @default(ACTIVE)
  permissions        Json?
  notificationPrefs  Json?      @map("notification_prefs")

  receipts            Receipt[]
  withdrawals         Withdrawal[]
  loans               Loan[]
  tradesAsSeller      Trade[]                      @relation("TradeSeller")
  tradesAsBuyer       Trade[]                      @relation("TradeBuyer")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  managerAssignments  WarehouseManagerAssignment[] @relation("ManagerAssignments")
  approvedReceipts    Receipt[]                    @relation("ReceiptApprover")
  approvedWithdrawals Withdrawal[]                 @relation("WithdrawalApprover")
  activityLogs        ActivityLog[]
  inventoryEvents     InventoryEvent[]
  clientProfile       ClientProfile?               @relation("ClientUser")
  registeredClients   ClientProfile[]              @relation("ClientRegistrar")
  notifications       Notification[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  roleId    String   @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  users UserRole[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Warehouse {
  id       String @id @default(uuid())
  name     String
  location String

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Extended fields from spec §1.0
  code       String?         @unique @map("code")
  type       String?
  state      String?
  address    String?
  capacityMt Float?          @map("capacity_mt")
  status     WarehouseStatus @default(ACTIVE)

  receipts             Receipt[]
  warehouseCommodities WarehouseCommodity[]
  managerAssignments   WarehouseManagerAssignment[]
  storageFeePolicies   StorageFeePolicy[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("warehouses")
}

model Commodity {
  id            String          @id @default(uuid())
  name          String          @unique
  description   String?
  unitOfMeasure MeasurementUnit @map("unit_of_measure")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Extended fields from spec §1.0
  gradingLogic        GradingLogic @default(PERCENTAGE) @map("grading_logic")
  numberOfGrades      Int          @default(3) @map("number_of_grades")
  code                String?      @unique
  standardBagWeightKg Float?       @map("standard_bag_weight_kg")

  receipts             Receipt[]
  warehouseCommodities WarehouseCommodity[]
  gradingParameters    GradingParameter[]
  storageFeePolicies   StorageFeePolicy[]
  clientFocus          ClientFocusCommodity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("commodities")
}

model GradingParameter {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  commodityId String    @map("commodity_id")
  commodity   Commodity @relation(fields: [commodityId], references: [id])

  name        String
  unit        String
  isDefective Boolean @default(false) @map("is_defective")
  thresholds  Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([commodityId, name])
  @@index([tenantId])
  @@index([commodityId])
  @@map("grading_parameters")
}

model StorageFeePolicy {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  warehouseId String?    @map("warehouse_id")
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  commodityId String?    @map("commodity_id")
  commodity   Commodity? @relation(fields: [commodityId], references: [id])

  feeType          FeeType          @map("fee_type")
  rate             Float
  billingFrequency BillingFrequency @map("billing_frequency")
  gracePeriodDays  Int              @map("grace_period_days")
  latePenaltyPct   Float            @map("late_penalty_pct")
  currency         String           @default("NGN")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([warehouseId])
  @@index([commodityId])
  @@index([isActive])
  @@map("storage_fee_policies")
}

model WarehouseManagerAssignment {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  managerId   String    @map("manager_id")
  manager     User      @relation("ManagerAssignments", fields: [managerId], references: [id])

  assignedAt   DateTime  @default(now()) @map("assigned_at")
  assignedBy   String    @map("assigned_by")
  unassignedAt DateTime? @map("unassigned_at")

  @@unique([warehouseId, managerId])
  @@index([tenantId])
  @@index([managerId])
  @@map("warehouse_manager_assignments")
}

// Immutable UTXO-style node in the receipt tree.
// `quantity` is write-once; state changes mint children + transition status.
// A leaf's available quantity = `quantity` iff status = ACTIVE & approvalStatus = APPROVED.
model Receipt {
  id            String        @id @default(uuid())
  receiptNumber String        @unique @map("receipt_number")
  status        ReceiptStatus @default(PENDING_APPROVAL)

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  commodityId String    @map("commodity_id")
  commodity   Commodity @relation(fields: [commodityId], references: [id])
  quantity    Decimal   @db.Decimal(18, 3)
  grade       String?

  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  clientId String @map("client_id")
  client   User   @relation(fields: [clientId], references: [id])

  // Approval workflow (kept as its own field — NOT unified into status)
  approvalStatus       ApprovalStatus @default(PENDING) @map("approval_status")
  approvedById         String?        @map("approved_by_id")
  approvedBy           User?          @relation("ReceiptApprover", fields: [approvedById], references: [id])
  approvedAt           DateTime?      @map("approved_at")
  rejectionReason      String?        @map("rejection_reason")
  gradingScores        Json?          @map("grading_scores")
  computedGrade        String?        @map("computed_grade")
  totalDefectivePct    Float?         @map("total_defective_pct")
  standardDeductionPct Float?         @map("standard_deduction_pct")

  // Tree lineage
  parentReceiptId String?   @map("parent_receipt_id")
  parentReceipt   Receipt?  @relation("ReceiptLineage", fields: [parentReceiptId], references: [id])
  childReceipts   Receipt[] @relation("ReceiptLineage")

  rootReceiptId String    @map("root_receipt_id")
  rootReceipt   Receipt   @relation("ReceiptRoot", fields: [rootReceiptId], references: [id])
  descendants   Receipt[] @relation("ReceiptRoot")

  isParent     Boolean   @default(false) @map("is_parent")
  supersededAt DateTime? @map("superseded_at")

  // Provenance — the transaction + ledger event that minted this node
  sourceTxnType TxnType?        @map("source_txn_type")
  sourceTxnId   String?         @map("source_txn_id")
  sourceEventId String?         @map("source_event_id")
  sourceEvent   InventoryEvent? @relation("ReceiptSourceEvent", fields: [sourceEventId], references: [id])
  eventsFrom    InventoryEvent[] @relation("ReceiptEventsFrom")

  dateOfDeposit DateTime  @map("date_of_deposit")
  expiryDate    DateTime? @map("expiry_date")

  withdrawals Withdrawal[]
  loans       Loan[]
  trades      Trade[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([commodityId])
  @@index([warehouseId])
  @@index([status])
  @@index([tenantId])
  @@index([rootReceiptId])
  @@index([parentReceiptId])
  @@index([sourceEventId])
  @@index([tenantId, status])
  @@index([clientId, status, commodityId])
  @@index([status, isParent])
  @@map("receipts")
}

// Append-only inventory ledger. Rows are NEVER updated or deleted.
// The receipt tree is authoritative for reads; this is the audit/retrace log
// and the source for the reconciliation / replay-verify gate.
model InventoryEvent {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  rootReceiptId String   @map("root_receipt_id")
  fromReceiptId String?  @map("from_receipt_id")
  fromReceipt   Receipt? @relation("ReceiptEventsFrom", fields: [fromReceiptId], references: [id])

  eventType InventoryEventType @map("event_type")
  txnType   TxnType?           @map("txn_type")
  txnId     String?            @map("txn_id")
  quantity  Decimal            @db.Decimal(18, 3)

  actorUserId String? @map("actor_user_id")
  actor       User?   @relation(fields: [actorUserId], references: [id])

  idempotencyKey    String?         @unique @map("idempotency_key")
  reversalOfEventId String?         @map("reversal_of_event_id")
  reversalOf        InventoryEvent? @relation("EventReversal", fields: [reversalOfEventId], references: [id])
  reversedBy        InventoryEvent[] @relation("EventReversal")

  createdReceipts Receipt[] @relation("ReceiptSourceEvent")

  metadata   Json?
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([rootReceiptId])
  @@index([txnType, txnId])
  @@index([tenantId, occurredAt])
  @@index([fromReceiptId])
  @@map("inventory_events")
}

// Depositor KYC profile, 1:1 with a CLIENT-role User. Created by a warehouse
// manager during client registration.
model ClientProfile {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation("ClientUser", fields: [userId], references: [id])

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  clientCode String     @unique @map("client_code")
  type       ClientType @default(FARMER)
  occupation String?
  description String?

  nationality   String?
  stateOfOrigin String? @map("state_of_origin")
  lga           String?
  nationalId    String? @map("national_id")

  // Multi-focus: a client can target several commodities. Use the
  // `focusCommodities` join below; the legacy single-FK column is dropped
  // in the 20260521_client_focus_commodities migration.
  focusCommodities ClientFocusCommodity[]

  profilePhotoUrl String? @map("profile_photo_url")
  idDocumentUrl   String? @map("id_document_url")

  bankAccountName   String? @map("bank_account_name")
  bankAccountNumber String? @map("bank_account_number")
  bankName          String? @map("bank_name")

  nokFullName     String? @map("nok_full_name")
  nokAddress      String? @map("nok_address")
  nokPhone        String? @map("nok_phone")
  nokEmail        String? @map("nok_email")
  nokRelationship String? @map("nok_relationship")

  registeredByManagerId String? @map("registered_by_manager_id")
  registeredByManager   User?   @relation("ClientRegistrar", fields: [registeredByManagerId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([registeredByManagerId])
  @@map("client_profiles")
}

// Many-to-many: a client can focus on several commodities, and a commodity
// can be the focus of several clients. Composite-unique prevents duplicate
// rows for the same (client, commodity) pair.
model ClientFocusCommodity {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  clientProfileId String        @map("client_profile_id")
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  commodityId     String        @map("commodity_id")
  commodity       Commodity     @relation(fields: [commodityId], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")

  @@unique([clientProfileId, commodityId])
  @@index([tenantId])
  @@index([commodityId])
  @@map("client_focus_commodities")
}

model Financier {
  id           String @id @default(uuid())
  name         String @unique
  interestRate Float  @map("interest_rate")
  minTenure    Int    @map("min_tenure")
  maxTenure    Int    @map("max_tenure")
  approvalTime String @map("approval_time")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  loans Loan[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("financiers")
}

model WarehouseCommodity {
  id                String @id @default(uuid())
  warehouseId       String @map("warehouse_id")
  commodityId       String @map("commodity_id")
  storageFeePerUnit Float  @map("storage_fee_per_unit")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  commodity Commodity @relation(fields: [commodityId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([warehouseId, commodityId])
  @@index([tenantId])
  @@map("warehouse_commodities")
}

model Withdrawal {
  id        String @id @default(uuid())
  reference String @unique

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  receiptId String  @map("receipt_id")
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  clientId String @map("client_id")
  client   User   @relation(fields: [clientId], references: [id])

  quantity    Float
  reason      String?
  plannedDate DateTime         @map("planned_date")
  status      WithdrawalStatus @default(PENDING_PAYMENT)

  storageFee  Float @map("storage_fee")
  handlingFee Float @map("handling_fee")
  totalFee    Float @map("total_fee")

  // Extended fields from spec §1.0
  approvedById    String?   @map("approved_by_id")
  approvedBy      User?     @relation("WithdrawalApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")
  feesBilledAt    DateTime? @map("fees_billed_at")
  currency        String    @default("NGN")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([receiptId])
  @@index([status])
  @@index([tenantId])
  @@map("withdrawals")
}

model Loan {
  id        String @id @default(uuid())
  reference String @unique

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  receiptId String  @map("receipt_id")
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  clientId String @map("client_id")
  client   User   @relation(fields: [clientId], references: [id])

  financierId String    @map("financier_id")
  financier   Financier @relation(fields: [financierId], references: [id])

  amount         Float
  interestRate   Float      @map("interest_rate")
  tenureMonths   Int        @map("tenure_months")
  totalInterest  Float      @map("total_interest")
  monthlyPayment Float      @map("monthly_payment")
  status         LoanStatus @default(PENDING)
  notes          String?
  currency       String     @default("NGN")

  approvedAt DateTime? @map("approved_at")
  repaidAt   DateTime? @map("repaid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([receiptId])
  @@index([financierId])
  @@index([status])
  @@index([tenantId])
  @@map("loans")
}

model Trade {
  id        String @id @default(uuid())
  reference String @unique

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  receiptId String  @map("receipt_id")
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  sellerId String @map("seller_id")
  seller   User   @relation("TradeSeller", fields: [sellerId], references: [id])

  buyerId String? @map("buyer_id")
  buyer   User?   @relation("TradeBuyer", fields: [buyerId], references: [id])

  quantity     Float
  pricePerUnit Float       @map("price_per_unit")
  totalPrice   Float       @map("total_price")
  status       TradeStatus @default(LISTED)
  currency     String      @default("NGN")

  settledAt DateTime? @map("settled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([buyerId])
  @@index([receiptId])
  @@index([status])
  @@index([tenantId])
  @@map("trades")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// One row per outstanding password-reset request. `tokenHash` is the
// SHA-256 of the random token we emailed to the user; the raw token is
// never stored. Tokens are one-time use (`usedAt` flips on consumption)
// and short-lived (30 min) so the threat window stays small.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model ActivityLog {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  userId   String? @map("user_id")
  user     User?   @relation(fields: [userId], references: [id])

  action      String // e.g., "RECEIPT_APPROVED", "CLIENT_CREATED"
  entityType  String // e.g., "RECEIPT", "USER"
  entityId    String? // The ID of the target entity
  description String?
  metadata    Json? // Store payload or state diff

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@index([entityId])
  @@map("activity_logs")
}

// Per-user notification surface. Recipient is `userId`; broadcasting to a
// role/group is implemented service-side by fanning out one row per recipient
// so reads remain a single indexed lookup.
//   - `relatedEntityType` + `relatedEntityId` let the bell deep-link into
//     the receipt / withdrawal / loan / trade / client view.
//   - `data` is a small JSON blob for any extras the UI needs without a
//     schema migration (amount, counterparty name, etc.).
model Notification {
  id     String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  userId   String @map("user_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  body    String?

  relatedEntityType String? @map("related_entity_type")
  relatedEntityId   String? @map("related_entity_id")
  data              Json?

  isRead  Boolean   @default(false) @map("is_read")
  readAt  DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([tenantId])
  @@index([userId, type, createdAt(sort: Desc)])
  @@map("notifications")
}

