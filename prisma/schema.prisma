generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum MeasurementUnit {
  METRIC_TON
  KILOGRAM
  METER
  BAG
  UNIT
  LITRE
}

// Phase 1: receipt-tree-ledger refactor.
// Node lifecycle for the immutable UTXO-style receipt tree.
enum ReceiptStatus {
  ACTIVE // live, transactable leaf
  PENDING_APPROVAL // graded by warehouse manager, awaiting approval
  HELD_WITHDRAWAL // reserved by an in-flight withdrawal
  HELD_LOAN // pledged as live loan collateral
  HELD_TRADE // listed on the exchange
  WITHDRAWN // terminal: physically removed
  TRADED_OUT // terminal: ownership transferred via sale
  SEIZED // terminal: collateral taken on loan default
  EXPIRED // terminal: lapsed
  CANCELLED // terminal: rejected deposit / dead
  SPLIT // superseded internal node (has children)
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TxnType {
  DEPOSIT
  WITHDRAWAL
  LOAN
  TRADE
  ADJUSTMENT
}

enum InventoryEventType {
  DEPOSIT
  APPROVED
  REJECTED
  HOLD_PLACED
  HOLD_RELEASED
  CONSUMED
  OWNERSHIP_TRANSFERRED
  SEIZED
  EXPIRED
  CANCELLED
  LEGACY_RECONCILIATION
}

enum WithdrawalStatus {
  PENDING_PAYMENT
  PAID_PENDING_APPROVAL
  APPROVED
  REJECTED
  COMPLETED
}

enum LoanStatus {
  PENDING
  APPROVED
  ACTIVE
  REPAID
  DEFAULTED
  REJECTED
  CANCELLED
}

enum TradeStatus {
  LISTED
  PENDING_SETTLEMENT
  SETTLED
  CANCELLED
}

enum GradingLogic {
  PERCENTAGE
  SCORE
  PASS_FAIL
}

enum FeeType {
  PER_MT_PER_MONTH
  PER_BAG_PER_WEEK
  PER_MT_PER_DAY
  FLAT_RATE
}

enum TransactionOtpPurpose {
  WITHDRAWAL
  LOAN
  TRADE
  DISABLE_2FA
  // CHANGE_PASSWORD is the step-up gate for an in-app password rotation.
  // Required whether or not the user has 2FA enabled — the OTP is the
  // proof-of-mailbox-control that stops anyone with session access (e.g.
  // a WM on a shared kiosk) from quietly changing the client's password.
  CHANGE_PASSWORD
}

enum NotificationType {
  // Client lifecycle
  CLIENT_REGISTERED
  CLIENT_CREDENTIALS_ISSUED

  // Deposits / receipt approval
  DEPOSIT_PENDING_APPROVAL
  DEPOSIT_APPROVED
  DEPOSIT_REJECTED

  // Withdrawals
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_PAYMENT_CONFIRMED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  WITHDRAWAL_DISPATCHED

  // Loans
  LOAN_REQUESTED
  LOAN_APPROVED
  LOAN_REJECTED
  LOAN_REPAID
  LOAN_DEFAULTED

  // Trades
  TRADE_LISTED
  TRADE_SOLD
  TRADE_CANCELLED
}

enum BillingFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DEACTIVATED
}

enum ClientType {
  FARMER
  TRADER
  COMPANY
  OTHER
}

// Distinguishes the legal nature of the client. INDIVIDUAL clients use the
// classic personal fields on User + ClientProfile; ORGANIZATION clients
// fill in the corporate block (RC number, directors, docs) and the User
// row represents their Authorized Representative.
enum ClientMode {
  INDIVIDUAL
  ORGANIZATION
}

// Company legal structure — straight from the corporate-onboarding form.
// `OTHER` captures the "Provide Detail" free-text via
// `companyCategoryOther` on the profile.
enum CompanyCategory {
  PARTNERSHIP
  PLC
  LLC
  COOPERATIVE
  OTHER
}

enum IdType {
  NIN
  INTERNATIONAL_PASSPORT
  DRIVERS_LICENSE
  VOTERS_CARD
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

// Document types we accept for a client. Names map 1:1 to the corporate-
// onboarding form's "Required Documentation" list, plus the per-person
// docs (passport photo / ID / utility bill) the rep and directors submit.
enum ClientDocumentType {
  // Company-level (ORGANIZATION mode only)
  CERTIFICATE_OF_INCORPORATION
  MEMORANDUM_AND_ARTICLES
  CAC_FORM_2_OR_7
  CAC_STATUS_REPORT
  TIN_CERTIFICATE
  BOARD_RESOLUTION
  COMPANY_UTILITY_BILL
  // Per-person (Authorized Representative or any Director)
  PASSPORT_PHOTO
  MEANS_OF_ID
  UTILITY_BILL
  // Anything else
  OTHER
}

// Whose document is this? COMPANY = belongs to the org itself.
// REPRESENTATIVE = belongs to the org's authorized rep (the User on the
// ClientProfile). DIRECTOR = belongs to a specific ClientDirector — in
// that case `scopeRefId` carries the director's id.
enum ClientDocumentScope {
  COMPANY
  REPRESENTATIVE
  DIRECTOR
}

// ==========================================
// MODELS
// ==========================================

model Tenant {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                User[]
  warehouses           Warehouse[]
  commodities          Commodity[]
  receipts             Receipt[]
  withdrawals          Withdrawal[]
  loans                Loan[]
  trades               Trade[]
  financiers           Financier[]
  warehouseCommodities WarehouseCommodity[]
  gradingParameters    GradingParameter[]
  storageFeePolicies   StorageFeePolicy[]
  managerAssignments   WarehouseManagerAssignment[]
  activityLogs         ActivityLog[]
  inventoryEvents      InventoryEvent[]
  clientProfiles       ClientProfile[]
  clientFocusCommodities ClientFocusCommodity[]
  clientDirectors      ClientDirector[]
  clientDocuments      ClientDocument[]
  notifications        Notification[]

  @@map("tenants")
}

model User {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  firstName String @map("first_name")
  lastName  String @map("last_name")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  roles UserRole[]

  // Profile fields from spec §1.0
  phoneNumber        String?    @map("phone_number")
  middleName         String?    @map("middle_name")
  dateOfBirth        DateTime?  @map("date_of_birth")
  gender             String?
  residentialAddress String?    @map("residential_address")
  employmentDate     DateTime?  @map("employment_date")
  managerCode        String?    @unique @map("manager_code")
  profilePhotoUrl    String?    @map("profile_photo_url")
  contactEmail       String?    @map("contact_email")
  status             UserStatus @default(ACTIVE)
  permissions        Json?
  notificationPrefs  Json?      @map("notification_prefs")

  // Transaction-time security (gated by the user's 2FA toggle):
  //  - `transactionPinHash` is a bcrypt hash of the 4-digit PIN the user
  //    sets in Settings. Required to be present before 2FA can be turned on.
  //  - `twoFactorEnabled` is the master switch. When TRUE, every
  //    withdrawal / loan / trade the user initiates also requires a
  //    fresh OTP delivered to their registered channel.
  transactionPinHash       String?   @map("transaction_pin_hash")
  transactionPinUpdatedAt  DateTime? @map("transaction_pin_updated_at")
  twoFactorEnabled         Boolean   @default(false) @map("two_factor_enabled")
  twoFactorEnabledAt       DateTime? @map("two_factor_enabled_at")

  receipts            Receipt[]
  withdrawals         Withdrawal[]
  loans               Loan[]
  tradesAsSeller      Trade[]                      @relation("TradeSeller")
  tradesAsBuyer       Trade[]                      @relation("TradeBuyer")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  managerAssignments  WarehouseManagerAssignment[] @relation("ManagerAssignments")
  approvedReceipts    Receipt[]                    @relation("ReceiptApprover")
  approvedWithdrawals Withdrawal[]                 @relation("WithdrawalApprover")
  activityLogs        ActivityLog[]
  inventoryEvents     InventoryEvent[]
  clientProfile       ClientProfile?               @relation("ClientUser")
  registeredClients   ClientProfile[]              @relation("ClientRegistrar")
  notifications       Notification[]
  transactionOtps     TransactionOtp[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  roleId    String   @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  users UserRole[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Warehouse {
  id       String @id @default(uuid())
  name     String
  location String

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Extended fields from spec §1.0
  code       String?         @unique @map("code")
  type       String?
  state      String?
  address    String?
  capacityMt Float?          @map("capacity_mt")
  status     WarehouseStatus @default(ACTIVE)

  // Shared warehouse credential — managers sign in as the warehouse, then
  // identify themselves (which person from the assigned roster did this).
  // `mustChangePassword` flips TRUE whenever a new manager is assigned, so
  // every "inheritance" forces a fresh password on next sign-in (rotating
  // the credential the prior team knew).
  email              String?   @unique
  passwordHash       String?   @map("password_hash")
  passwordSetAt      DateTime? @map("password_set_at")
  mustChangePassword Boolean   @default(true) @map("must_change_password")

  receipts             Receipt[]
  warehouseCommodities WarehouseCommodity[]
  managerAssignments   WarehouseManagerAssignment[]
  storageFeePolicies   StorageFeePolicy[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("warehouses")
}

model Commodity {
  id            String          @id @default(uuid())
  name          String          @unique
  description   String?
  unitOfMeasure MeasurementUnit @map("unit_of_measure")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Extended fields from spec §1.0
  gradingLogic        GradingLogic @default(PERCENTAGE) @map("grading_logic")
  numberOfGrades      Int          @default(3) @map("number_of_grades")
  code                String?      @unique
  standardBagWeightKg Float?       @map("standard_bag_weight_kg")

  receipts             Receipt[]
  warehouseCommodities WarehouseCommodity[]
  gradingParameters    GradingParameter[]
  storageFeePolicies   StorageFeePolicy[]
  clientFocus          ClientFocusCommodity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("commodities")
}

model GradingParameter {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  commodityId String    @map("commodity_id")
  commodity   Commodity @relation(fields: [commodityId], references: [id])

  name        String
  unit        String
  isDefective Boolean @default(false) @map("is_defective")
  thresholds  Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([commodityId, name])
  @@index([tenantId])
  @@index([commodityId])
  @@map("grading_parameters")
}

model StorageFeePolicy {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  warehouseId String?    @map("warehouse_id")
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  commodityId String?    @map("commodity_id")
  commodity   Commodity? @relation(fields: [commodityId], references: [id])

  feeType          FeeType          @map("fee_type")
  rate             Float
  billingFrequency BillingFrequency @map("billing_frequency")
  gracePeriodDays  Int              @map("grace_period_days")
  latePenaltyPct   Float            @map("late_penalty_pct")
  currency         String           @default("NGN")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([warehouseId])
  @@index([commodityId])
  @@index([isActive])
  @@map("storage_fee_policies")
}

model WarehouseManagerAssignment {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  managerId   String    @map("manager_id")
  manager     User      @relation("ManagerAssignments", fields: [managerId], references: [id])

  assignedAt   DateTime  @default(now()) @map("assigned_at")
  assignedBy   String    @map("assigned_by")
  unassignedAt DateTime? @map("unassigned_at")

  @@unique([warehouseId, managerId])
  @@index([tenantId])
  @@index([managerId])
  @@map("warehouse_manager_assignments")
}

// Immutable UTXO-style node in the receipt tree.
// `quantity` is write-once; state changes mint children + transition status.
// A leaf's available quantity = `quantity` iff status = ACTIVE & approvalStatus = APPROVED.
model Receipt {
  id            String        @id @default(uuid())
  receiptNumber String        @unique @map("receipt_number")
  status        ReceiptStatus @default(PENDING_APPROVAL)

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  commodityId String    @map("commodity_id")
  commodity   Commodity @relation(fields: [commodityId], references: [id])
  quantity    Decimal   @db.Decimal(18, 3)
  grade       String?

  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  clientId String @map("client_id")
  client   User   @relation(fields: [clientId], references: [id])

  // Approval workflow (kept as its own field — NOT unified into status)
  approvalStatus       ApprovalStatus @default(PENDING) @map("approval_status")
  approvedById         String?        @map("approved_by_id")
  approvedBy           User?          @relation("ReceiptApprover", fields: [approvedById], references: [id])
  approvedAt           DateTime?      @map("approved_at")
  rejectionReason      String?        @map("rejection_reason")
  gradingScores        Json?          @map("grading_scores")
  computedGrade        String?        @map("computed_grade")
  totalDefectivePct    Float?         @map("total_defective_pct")
  standardDeductionPct Float?         @map("standard_deduction_pct")

  // Tree lineage
  parentReceiptId String?   @map("parent_receipt_id")
  parentReceipt   Receipt?  @relation("ReceiptLineage", fields: [parentReceiptId], references: [id])
  childReceipts   Receipt[] @relation("ReceiptLineage")

  rootReceiptId String    @map("root_receipt_id")
  rootReceipt   Receipt   @relation("ReceiptRoot", fields: [rootReceiptId], references: [id])
  descendants   Receipt[] @relation("ReceiptRoot")

  isParent     Boolean   @default(false) @map("is_parent")
  supersededAt DateTime? @map("superseded_at")

  // Provenance — the transaction + ledger event that minted this node
  sourceTxnType TxnType?        @map("source_txn_type")
  sourceTxnId   String?         @map("source_txn_id")
  sourceEventId String?         @map("source_event_id")
  sourceEvent   InventoryEvent? @relation("ReceiptSourceEvent", fields: [sourceEventId], references: [id])
  eventsFrom    InventoryEvent[] @relation("ReceiptEventsFrom")

  dateOfDeposit DateTime  @map("date_of_deposit")
  expiryDate    DateTime? @map("expiry_date")

  withdrawals Withdrawal[]
  loans       Loan[]
  trades      Trade[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([commodityId])
  @@index([warehouseId])
  @@index([status])
  @@index([tenantId])
  @@index([rootReceiptId])
  @@index([parentReceiptId])
  @@index([sourceEventId])
  @@index([tenantId, status])
  @@index([clientId, status, commodityId])
  @@index([status, isParent])
  @@map("receipts")
}

// Append-only inventory ledger. Rows are NEVER updated or deleted.
// The receipt tree is authoritative for reads; this is the audit/retrace log
// and the source for the reconciliation / replay-verify gate.
model InventoryEvent {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  rootReceiptId String   @map("root_receipt_id")
  fromReceiptId String?  @map("from_receipt_id")
  fromReceipt   Receipt? @relation("ReceiptEventsFrom", fields: [fromReceiptId], references: [id])

  eventType InventoryEventType @map("event_type")
  txnType   TxnType?           @map("txn_type")
  txnId     String?            @map("txn_id")
  quantity  Decimal            @db.Decimal(18, 3)

  actorUserId String? @map("actor_user_id")
  actor       User?   @relation(fields: [actorUserId], references: [id])

  idempotencyKey    String?         @unique @map("idempotency_key")
  reversalOfEventId String?         @map("reversal_of_event_id")
  reversalOf        InventoryEvent? @relation("EventReversal", fields: [reversalOfEventId], references: [id])
  reversedBy        InventoryEvent[] @relation("EventReversal")

  createdReceipts Receipt[] @relation("ReceiptSourceEvent")

  metadata   Json?
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([rootReceiptId])
  @@index([txnType, txnId])
  @@index([tenantId, occurredAt])
  @@index([fromReceiptId])
  @@map("inventory_events")
}

// Depositor KYC profile, 1:1 with a CLIENT-role User. Created by a warehouse
// manager during client registration.
model ClientProfile {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation("ClientUser", fields: [userId], references: [id])

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  clientCode String     @unique @map("client_code")
  type       ClientType @default(FARMER)

  // INDIVIDUAL is the legacy / default path. ORGANIZATION enables the
  // corporate-onboarding fields below + directors[] + documents[].
  mode       ClientMode @default(INDIVIDUAL)

  occupation String?
  description String?

  nationality   String?
  stateOfOrigin String? @map("state_of_origin")
  lga           String?
  nationalId    String? @map("national_id")

  // ── Organization-only fields (NULL when mode = INDIVIDUAL) ──────────────
  rcNumber             String?          @map("rc_number")
  companyName          String?          @map("company_name")
  companyCategory      CompanyCategory? @map("company_category")
  companyCategoryOther String?          @map("company_category_other")
  dateOfIncorporation  DateTime?        @map("date_of_incorporation")
  natureOfBusiness     String?          @map("nature_of_business")
  sectorIndustry       String?          @map("sector_industry")
  businessAddress      String?          @map("business_address")
  tin                  String?

  // ── Authorized Representative (org mode) / additional KYC (individual) ──
  // For ORGANIZATION clients these describe the rep; for INDIVIDUAL clients
  // they're optional self-KYC fields the form may collect.
  representativeDesignation String?        @map("representative_designation")
  otherNames                String?        @map("other_names")
  mothersMaidenName         String?        @map("mothers_maiden_name")
  maritalStatus             MaritalStatus? @map("marital_status")
  idType                    IdType?        @map("id_type")
  idNumber                  String?        @map("id_number")
  idIssueDate               DateTime?      @map("id_issue_date")
  idExpiryDate              DateTime?      @map("id_expiry_date")

  // Multi-focus: a client can target several commodities. Use the
  // `focusCommodities` join below; the legacy single-FK column is dropped
  // in the 20260521_client_focus_commodities migration.
  focusCommodities ClientFocusCommodity[]

  profilePhotoUrl String? @map("profile_photo_url")
  idDocumentUrl   String? @map("id_document_url")

  bankAccountName   String? @map("bank_account_name")
  bankAccountNumber String? @map("bank_account_number")
  bankName          String? @map("bank_name")

  nokFullName     String? @map("nok_full_name")
  nokAddress      String? @map("nok_address")
  nokPhone        String? @map("nok_phone")
  nokEmail        String? @map("nok_email")
  nokRelationship String? @map("nok_relationship")

  registeredByManagerId String? @map("registered_by_manager_id")
  registeredByManager   User?   @relation("ClientRegistrar", fields: [registeredByManagerId], references: [id])

  // ORGANIZATION-mode children. Cascade on delete so removing a client
  // takes its directors + documents with it.
  directors ClientDirector[]
  documents ClientDocument[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([registeredByManagerId])
  @@map("client_profiles")
}

// One row per director on an ORGANIZATION-mode client. Mirrors the
// "Director Details + ADD" repeatable section of the corporate-onboarding
// form. INDIVIDUAL clients have no directors; the relation is left empty.
model ClientDirector {
  id                String        @id @default(uuid())
  tenantId          String        @map("tenant_id")
  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  clientProfileId   String        @map("client_profile_id")
  clientProfile     ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  firstName          String         @map("first_name")
  lastName           String         @map("last_name")
  otherNames         String?        @map("other_names")
  designation        String?
  residentialAddress String?        @map("residential_address")
  phoneNumber        String?        @map("phone_number")
  email              String?
  mothersMaidenName  String?        @map("mothers_maiden_name")
  gender             String?
  dateOfBirth        DateTime?      @map("date_of_birth")
  nationality        String?
  stateOfOrigin      String?        @map("state_of_origin")
  maritalStatus      MaritalStatus? @map("marital_status")
  bvn                String?
  nin                String?
  idType             IdType?        @map("id_type")
  idNumber           String?        @map("id_number")
  idIssueDate        DateTime?      @map("id_issue_date")
  idExpiryDate       DateTime?      @map("id_expiry_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientProfileId])
  @@index([tenantId])
  @@map("client_directors")
}

// Stored document reference. We don't host files — FE uploads to its
// configured storage (S3 / DO Spaces / etc.) and POSTs the resulting URL
// alongside the document type and scope. Adding a real upload pipeline is
// a follow-up that doesn't change this shape.
model ClientDocument {
  id              String              @id @default(uuid())
  tenantId        String              @map("tenant_id")
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  clientProfileId String              @map("client_profile_id")
  clientProfile   ClientProfile       @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  type      ClientDocumentType
  scope     ClientDocumentScope
  // When scope = DIRECTOR, this carries the ClientDirector.id whose document
  // this is. No formal FK — kept loose so a director row can be replaced
  // without orphaning its docs (the FE is expected to clean up).
  scopeRefId String? @map("scope_ref_id")

  url      String
  fileName String? @map("file_name")
  fileSize Int?    @map("file_size")
  mimeType String? @map("mime_type")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientProfileId, scope])
  @@index([tenantId])
  @@map("client_documents")
}

// Many-to-many: a client can focus on several commodities, and a commodity
// can be the focus of several clients. Composite-unique prevents duplicate
// rows for the same (client, commodity) pair.
model ClientFocusCommodity {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  clientProfileId String        @map("client_profile_id")
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  commodityId     String        @map("commodity_id")
  commodity       Commodity     @relation(fields: [commodityId], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")

  @@unique([clientProfileId, commodityId])
  @@index([tenantId])
  @@index([commodityId])
  @@map("client_focus_commodities")
}

model Financier {
  id           String @id @default(uuid())
  name         String @unique
  interestRate Float  @map("interest_rate")
  minTenure    Int    @map("min_tenure")
  maxTenure    Int    @map("max_tenure")
  approvalTime String @map("approval_time")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  loans Loan[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("financiers")
}

model WarehouseCommodity {
  id                String @id @default(uuid())
  warehouseId       String @map("warehouse_id")
  commodityId       String @map("commodity_id")
  storageFeePerUnit Float  @map("storage_fee_per_unit")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  commodity Commodity @relation(fields: [commodityId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([warehouseId, commodityId])
  @@index([tenantId])
  @@map("warehouse_commodities")
}

model Withdrawal {
  id        String @id @default(uuid())
  reference String @unique

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  receiptId String  @map("receipt_id")
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  clientId String @map("client_id")
  client   User   @relation(fields: [clientId], references: [id])

  quantity    Float
  reason      String?
  plannedDate DateTime         @map("planned_date")
  status      WithdrawalStatus @default(PENDING_PAYMENT)

  storageFee  Float @map("storage_fee")
  handlingFee Float @map("handling_fee")
  totalFee    Float @map("total_fee")

  // Extended fields from spec §1.0
  approvedById    String?   @map("approved_by_id")
  approvedBy      User?     @relation("WithdrawalApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")
  feesBilledAt    DateTime? @map("fees_billed_at")
  currency        String    @default("NGN")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([receiptId])
  @@index([status])
  @@index([tenantId])
  @@map("withdrawals")
}

model Loan {
  id        String @id @default(uuid())
  reference String @unique

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  receiptId String  @map("receipt_id")
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  clientId String @map("client_id")
  client   User   @relation(fields: [clientId], references: [id])

  financierId String    @map("financier_id")
  financier   Financier @relation(fields: [financierId], references: [id])

  amount         Float
  interestRate   Float      @map("interest_rate")
  tenureMonths   Int        @map("tenure_months")
  totalInterest  Float      @map("total_interest")
  monthlyPayment Float      @map("monthly_payment")
  status         LoanStatus @default(PENDING)
  notes          String?
  currency       String     @default("NGN")

  approvedAt DateTime? @map("approved_at")
  repaidAt   DateTime? @map("repaid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([receiptId])
  @@index([financierId])
  @@index([status])
  @@index([tenantId])
  @@map("loans")
}

model Trade {
  id        String @id @default(uuid())
  reference String @unique

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  receiptId String  @map("receipt_id")
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  sellerId String @map("seller_id")
  seller   User   @relation("TradeSeller", fields: [sellerId], references: [id])

  buyerId String? @map("buyer_id")
  buyer   User?   @relation("TradeBuyer", fields: [buyerId], references: [id])

  quantity     Float
  pricePerUnit Float       @map("price_per_unit")
  totalPrice   Float       @map("total_price")
  status       TradeStatus @default(LISTED)
  currency     String      @default("NGN")

  settledAt DateTime? @map("settled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([buyerId])
  @@index([receiptId])
  @@index([status])
  @@index([tenantId])
  @@map("trades")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// Short-lived OTPs the client receives when 2FA-gated transactions are in
// flight. SHA-256 hash of the 6-digit code is stored (never the raw code).
// `attempts` counts wrong submissions so we can lock out a guessing bot
// without blocking the legitimate user from requesting a fresh code.
// `purpose` lets us pin a code to a specific transaction type — a withdrawal
// OTP can't be replayed against a loan and vice-versa.
model TransactionOtp {
  id        String                @id @default(uuid())
  userId    String                @map("user_id")
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String                @map("code_hash")
  purpose   TransactionOtpPurpose
  expiresAt DateTime              @map("expires_at")
  usedAt    DateTime?             @map("used_at")
  attempts  Int                   @default(0)
  createdAt DateTime              @default(now()) @map("created_at")

  @@index([userId, purpose, usedAt])
  @@map("transaction_otps")
}

// One row per outstanding password-reset request. `tokenHash` is the
// SHA-256 of the random token we emailed to the user; the raw token is
// never stored. Tokens are one-time use (`usedAt` flips on consumption)
// and short-lived (30 min) so the threat window stays small.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model ActivityLog {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  userId   String? @map("user_id")
  user     User?   @relation(fields: [userId], references: [id])

  action      String // e.g., "RECEIPT_APPROVED", "CLIENT_CREATED"
  entityType  String // e.g., "RECEIPT", "USER"
  entityId    String? // The ID of the target entity
  description String?
  metadata    Json? // Store payload or state diff

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@index([entityId])
  @@map("activity_logs")
}

// Per-user notification surface. Recipient is `userId`; broadcasting to a
// role/group is implemented service-side by fanning out one row per recipient
// so reads remain a single indexed lookup.
//   - `relatedEntityType` + `relatedEntityId` let the bell deep-link into
//     the receipt / withdrawal / loan / trade / client view.
//   - `data` is a small JSON blob for any extras the UI needs without a
//     schema migration (amount, counterparty name, etc.).
model Notification {
  id     String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  userId   String @map("user_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  body    String?

  relatedEntityType String? @map("related_entity_type")
  relatedEntityId   String? @map("related_entity_id")
  data              Json?

  isRead  Boolean   @default(false) @map("is_read")
  readAt  DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([tenantId])
  @@index([userId, type, createdAt(sort: Desc)])
  @@map("notifications")
}

