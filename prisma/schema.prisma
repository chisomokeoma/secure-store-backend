// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

// Role Model will be used instead of Enum
enum MeasurementUnit {
  METRIC_TON
  KILOGRAM
  METER
  BAG
  UNIT
  LITRE
}

enum ReceiptStatus {
  ACTIVE
  CANCELLED
  LIEN
  PLEDGED
  EXPIRED
}

enum WithdrawalStatus {
  PENDING_PAYMENT
  PAID_PENDING_APPROVAL
  APPROVED
  REJECTED
  COMPLETED
}

// ==========================================
// MODELS
// ==========================================

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  roleId    String? @map("role_id")
  role      Role?   @relation(fields: [roleId], references: [id])

  // Relations
  receipts    Receipt[]
  withdrawals Withdrawal[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Warehouse {
  id       String @id @default(uuid())
  name     String
  location String

  // Relations
  receipts             Receipt[]
  warehouseCommodities WarehouseCommodity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("warehouses")
}

model Commodity {
  id            String          @id @default(uuid())
  name          String          @unique
  description   String?
  unitOfMeasure MeasurementUnit @map("unit_of_measure")

  // Relations
  receipts             Receipt[]
  warehouseCommodities WarehouseCommodity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("commodities")
}

model Receipt {
  id            String        @id @default(uuid())
  receiptNumber String        @unique @map("receipt_number") // e.g., WR-2025-01
  status        ReceiptStatus @default(ACTIVE)

  // Commodity Information
  commodityId       String    @map("commodity_id")
  commodity         Commodity @relation(fields: [commodityId], references: [id])
  quantity          Float
  quantityAvailable Float?    @map("quantity_available")
  grade             String?

  // Storage Information
  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  // Ownership
  clientId String @map("client_id")
  client   User   @relation(fields: [clientId], references: [id])

  dateOfDeposit DateTime  @map("date_of_deposit")
  expiryDate    DateTime? @map("expiry_date")

  withdrawals Withdrawal[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([commodityId])
  @@index([warehouseId])
  @@index([status])
  @@map("receipts")
}

model Financier {
  id           String @id @default(uuid())
  name         String @unique
  interestRate Float  @map("interest_rate")
  minTenure    Int    @map("min_tenure")
  maxTenure    Int    @map("max_tenure")
  approvalTime String @map("approval_time")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("financiers")
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  users User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model WarehouseCommodity {
  id                String @id @default(uuid())
  warehouseId       String @map("warehouse_id")
  commodityId       String @map("commodity_id")
  storageFeePerUnit Float  @map("storage_fee_per_unit")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  commodity Commodity @relation(fields: [commodityId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([warehouseId, commodityId])
  @@map("warehouse_commodities")
}

model Withdrawal {
  id        String @id @default(uuid())
  reference String @unique

  receiptId String  @map("receipt_id")
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  clientId String @map("client_id")
  client   User   @relation(fields: [clientId], references: [id])

  quantity    Float
  reason      String?
  plannedDate DateTime         @map("planned_date")
  status      WithdrawalStatus @default(PENDING_PAYMENT)

  // Fees
  storageFee  Float @map("storage_fee")
  handlingFee Float @map("handling_fee")
  totalFee    Float @map("total_fee")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([receiptId])
  @@index([status])
  @@map("withdrawals")
}
